{
  "name": "@vfos/shopee",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "shopee:login": "tsx scripts/login-session.ts",
    "shopee:fetch": "tsx scripts/fetch-offers.ts",
    "shopee:fetch-cookie": "tsx scripts/fetch-offers-cookie.ts",
    "shopee:extract-links-cdp": "tsx scripts/extract-links-cdp.ts",
    "debug:shopee:picks": "tsx scripts/debug/load-picks.ts",
    "debug:shopee:test-single-cdp": "tsx scripts/debug/test-single-link-cdp.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "playwright": "^1.51.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
