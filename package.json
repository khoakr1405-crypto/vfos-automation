{
  "name": "vfos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./plugins/*\" --filter \"./apps/*\" build",
    "dev": "pnpm --filter @vfos/kernel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "smoke": "pnpm --filter @vfos/kernel smoke",
    "growth:smoke": "tsx apps/studio/scripts/growth-data-smoke.ts",
    "growth:weekly-report": "tsx apps/studio/scripts/generate-weekly-report.ts",
    "voice:generate": "tsx packages/voice/scripts/generate.ts",
    "voice:sync": "tsx packages/voice/scripts/sync.ts",
    "voice:elevenlabs": "tsx scripts/elevenlabs-voiceover-bridge.ts",
    "caption:kinetic": "tsx scripts/kinetic-caption-renderer.ts",
    "bgm:mix": "tsx packages/voice/scripts/bgm-mix.ts",
    "bgm:check": "tsx scripts/job-bgm-selector.ts --check",
    "bgm:gen": "tsx scripts/bgm-generate-candidates.ts",
    "bgm:validate": "tsx scripts/bgm-validate-library.ts",
    "script:generate": "tsx packages/script-writer/scripts/generate.ts",
    "facebook:test": "tsx packages/facebook/scripts/test-connection.ts",
    "facebook:test-post": "tsx packages/facebook/scripts/test-post.ts",
