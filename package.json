    "job:status": "tsx scripts/vfos-job-manager.ts status",
    "job:attach-source": "tsx scripts/vfos-job-manager.ts attach-source",
    "job:source-inbox": "tsx scripts/vfos-job-manager.ts source-inbox",
    "job:script": "tsx scripts/vfos-job-manager.ts script",
    "job:approve": "tsx scripts/vfos-job-manager.ts approve",
    "job:reject": "tsx scripts/vfos-job-manager.ts reject",
    "job:package": "tsx scripts/vfos-job-manager.ts package",
    "job:list": "tsx scripts/vfos-job-manager.ts list",
    "job:vision": "tsx scripts/job-video-vision-analyzer.ts",
