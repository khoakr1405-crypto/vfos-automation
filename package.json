{
  "name": "vfos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./plugins/*\" --filter \"./apps/*\" build",
    "dev": "pnpm --filter @vfos/kernel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "smoke": "pnpm --filter @vfos/kernel smoke",
    "voice:generate": "tsx packages/voice/scripts/generate.ts",
    "voice:sync": "tsx packages/voice/scripts/sync.ts",
    "voice:elevenlabs": "tsx scripts/elevenlabs-voiceover-bridge.ts",
    "caption:kinetic": "tsx scripts/kinetic-caption-renderer.ts",
    "bgm:mix": "tsx packages/voice/scripts/bgm-mix.ts",
    "script:generate": "tsx packages/script-writer/scripts/generate.ts",
    "facebook:test": "tsx packages/facebook/scripts/test-connection.ts",
    "facebook:test-post": "tsx packages/facebook/scripts/test-post.ts",
    "facebook:get-page-token": "tsx packages/facebook/scripts/get-page-token.ts",
    "facebook:preflight": "tsx scripts/facebook-preflight-demo.ts",
    "facebook:publish-verify": "tsx scripts/facebook-publish-verify-demo.ts",
    "facebook:multi-preflight": "tsx scripts/facebook-multi-page-verify-demo.ts",
    "shopee:login": "tsx packages/shopee/scripts/login-session.ts",
    "shopee:fetch": "tsx packages/shopee/scripts/fetch-offers.ts",
    "shopee:fetch-cookie": "tsx packages/shopee/scripts/fetch-offers-cookie.ts",
    "shopee:fetch-products": "tsx packages/shopee/scripts/fetch-products-cookie.ts",
    "shopee:select": "tsx packages/shopee/scripts/select-products.ts",
    "shopee:extract-links-cdp": "tsx packages/shopee/scripts/extract-links-cdp.ts",
    "status": "tsx scripts/status-cli.ts",
    "step:demo": "tsx scripts/step-demo.ts",
    "pipeline:demo": "tsx scripts/auto-pipeline-demo.ts",
    "pipeline:p3-demo": "tsx scripts/pipeline-p3-demo.ts",
    "pipeline:p4-demo": "tsx scripts/pipeline-p4-demo.ts",
    "pipeline:p5-demo": "tsx scripts/pipeline-p5-demo.ts",
    "offline-product-select": "tsx scripts/offline-product-select-demo.ts",
    "pipeline:p6-demo": "tsx scripts/pipeline-p6-demo.ts",
    "pipeline:p7-demo": "tsx scripts/pipeline-p7-demo.ts",
    "pipeline:p8-demo": "tsx scripts/pipeline-p8-demo.ts",
    "pipeline:p9-demo": "tsx scripts/pipeline-p9-demo.ts",
    "offline-visual-metadata": "tsx scripts/offline-visual-metadata-demo.ts",
    "pipeline:p10-demo": "tsx scripts/pipeline-p10-demo.ts",
    "pipeline:run-manifest": "tsx scripts/pipeline-run-manifest.ts",
    "offline-script-generate": "tsx scripts/offline-script-generate-demo.ts",
    "offline-voice-generate": "tsx scripts/offline-voice-generate-demo.ts",
    "offline-render-manifest": "tsx scripts/offline-render-manifest-demo.ts",
    "offline-render-video": "tsx scripts/offline-render-video-demo.ts",
    "offline-approval-gate": "tsx scripts/offline-approval-gate-demo.ts",
    "offline-publish-manifest": "tsx scripts/offline-publish-manifest-demo.ts",
    "chay": "tsx scripts/chay.ts",
    "chay:review": "tsx scripts/review-video-orchestrator.ts",
    "shopee:preflight": "tsx scripts/shopee-cdp-preflight-demo.ts",
    "shopee:extractor": "tsx scripts/shopee-link-extractor-demo.ts",
    "shopee:builder": "tsx scripts/shopee-product-card-builder.ts",
    "shopee:bgm": "tsx scripts/bgm-selector-demo.ts",
    "shopee:bgm-gen": "tsx scripts/bgm-generator-demo.ts",
    "operator:review-pack": "tsx scripts/operator-review-pack-demo.ts",
    "publish:facebook": "tsx scripts/facebook-publish-command-demo.ts",
    "production:pack": "tsx scripts/production-packager.ts",
    "shopee:audit": "tsx scripts/shopee-link-audit-demo.ts",
    "commerce:intake": "tsx scripts/commerce-intake-orchestrator.ts",
    "vfos:daily": "tsx scripts/vfos-daily-dashboard.ts",
    "vfos:sync-check": "tsx scripts/vfos-git-sync-guard.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
