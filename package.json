{
  "name": "vfos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./plugins/*\" --filter \"./apps/*\" build",
    "dev": "pnpm --filter @vfos/kernel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "fmt": "biome format --write .",
    "smoke": "pnpm --filter @vfos/kernel smoke",
    "voice:generate": "tsx packages/voice/scripts/generate.ts",
    "voice:sync": "tsx packages/voice/scripts/sync.ts",
    "bgm:mix": "tsx packages/voice/scripts/bgm-mix.ts",
    "script:generate": "tsx packages/script-writer/scripts/generate.ts",
    "facebook:test": "tsx packages/facebook/scripts/test-connection.ts",
    "facebook:test-post": "tsx packages/facebook/scripts/test-post.ts",
    "facebook:get-page-token": "tsx packages/facebook/scripts/get-page-token.ts",
    "shopee:login": "tsx packages/shopee/scripts/login-session.ts",
    "shopee:fetch": "tsx packages/shopee/scripts/fetch-offers.ts",
    "shopee:fetch-cookie": "tsx packages/shopee/scripts/fetch-offers-cookie.ts",
    "shopee:fetch-products": "tsx packages/shopee/scripts/fetch-products-cookie.ts",
    "shopee:select": "tsx packages/shopee/scripts/select-products.ts",
    "shopee:extract-links-cdp": "tsx packages/shopee/scripts/extract-links-cdp.ts",
    "status": "tsx scripts/status-cli.ts",
    "step:demo": "tsx scripts/step-demo.ts",
    "pipeline:demo": "tsx scripts/auto-pipeline-demo.ts",
    "pipeline:p3-demo": "tsx scripts/pipeline-p3-demo.ts",
    "pipeline:p4-demo": "tsx scripts/pipeline-p4-demo.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
