{
  "laneVersion": "v1",
  "lane": "review_product",
  "description": "Default review product lane for VFOS auto-pipeline",
  "defaults": {
    "timeoutMs": 10000,
    "outputDirPattern": "data/temp/pipeline-p8-demo/{runId}"
  },
  "steps": [
    {
      "stepName": "demo:product-match",
      "description": "Production-like offline Shopee candidate selection and match builder",
      "command": "tsx",
      "argsTemplate": [
        "scripts/offline-product-select-demo.ts",
        "--candidatesFile",
        "{inputs.productCandidatesPath}",
        "--outFile",
        "{outputDir}/product_match_artifact.json",
        "--productId",
        "2",
        "{extraArgs}"
      ],
      "cwd": ".",
      "timeoutMs": 15000,
      "expectedArtifacts": [
        {
          "pathTemplate": "{outputDir}/product_match_artifact.json",
          "required": true,
          "nonEmpty": true
        }
      ],
      "guards": [
        {
          "guardName": "ProductMatchGuard",
          "artifactPathTemplate": "{outputDir}/product_match_artifact.json",
          "blocking": true
        }
      ]
    },
    {
      "stepName": "demo:visual-check",
      "description": "Production-like offline video visual metadata builder",
      "command": "tsx",
      "argsTemplate": [
        "scripts/offline-visual-metadata-demo.ts",
        "--output",
        "{outputDir}/visual_metadata_artifact.json",
        "--mode",
        "{mode}"
      ],
      "cwd": ".",
      "timeoutMs": 10000,
      "expectedArtifacts": [
        {
          "pathTemplate": "{outputDir}/visual_metadata_artifact.json",
          "required": true,
          "nonEmpty": true
        }
      ],
      "guards": [
        {
          "guardName": "VisualGuard",
          "artifactPathTemplate": "{outputDir}/visual_metadata_artifact.json",
          "blocking": true
        }
      ]
    },
    {
      "stepName": "demo:script-generate",
      "description": "Production-like offline AI voiceover script generator",
      "command": "tsx",
      "argsTemplate": [
        "scripts/offline-script-generate-demo.ts",
        "--output",
        "{outputDir}/script_artifact.json",
        "--mode",
        "{mode}"
      ],
      "cwd": ".",
      "timeoutMs": 10000,
      "expectedArtifacts": [
        {
          "pathTemplate": "{outputDir}/script_artifact.json",
          "required": true,
          "nonEmpty": true
        }
      ],
      "guards": [
        {
          "guardName": "ScriptGuard",
          "artifactPathTemplate": "{outputDir}/script_artifact.json",
          "blocking": true
        }
      ]
    },
    {
      "stepName": "demo:voice-generate",
      "description": "Production-like offline AI voiceover audio generator",
      "command": "tsx",
      "argsTemplate": [
        "scripts/offline-voice-generate-demo.ts",
        "--script",
        "{outputDir}/script_artifact.json",
        "--output",
        "{outputDir}/voice_artifact.json",
        "--mode",
        "{mode}"
      ],
      "cwd": ".",
      "timeoutMs": 10000,
      "expectedArtifacts": [
        {
          "pathTemplate": "{outputDir}/voice_artifact.json",
          "required": true,
          "nonEmpty": true
        }
      ]
    },
    {
      "stepName": "demo:render-manifest",
      "description": "Production-like offline video render manifest builder",
      "command": "tsx",
      "argsTemplate": [
        "scripts/offline-render-manifest-demo.ts",
        "--visual",
        "{outputDir}/visual_metadata_artifact.json",
        "--script",
        "{outputDir}/script_artifact.json",
        "--voice",
        "{outputDir}/voice_artifact.json",
        "--output",
        "{outputDir}/render_manifest.json",
        "--mode",
        "{mode}"
      ],
      "cwd": ".",
      "timeoutMs": 10000,
      "expectedArtifacts": [
        {
          "pathTemplate": "{outputDir}/render_manifest.json",
          "required": true,
          "nonEmpty": true
        }
      ]
    },
    {
      "stepName": "demo:publish",
      "description": "Downstream Publish Step",
      "command": "node",
      "argsTemplate": [
        "-e",
        "{publishCommand}"
      ],
      "cwd": ".",
      "timeoutMs": 5000,
      "expectedArtifacts": []
    }
  ]
}
