# Claude Code private files
.claude/CLAUDE.local.md
.claude/settings.local.json
.claude/*.local.*

# Env & secrets
.env
.env.local
.env.*.local
*.key
*.pem

# Browser session storage / cookies / tokens (Shopee Session Fetcher v0)
# NEVER commit anything in .secrets/ — contains cookies, storageState, captcha
# screenshots, debug HTML snapshots with auth state, etc.
.secrets/
*.storage_state.json
*.session.json
*.cookies.json

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# Runtime data (local)
data/
data-*/

# Large backup archives
*.zip

# Admin tokens (auto-generated)
admin-token.txt

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Large binary media artifacts in production pipeline
production/**/*.mp4
production/**/*.mp3
production/**/*.m4a
production/**/*.wav
production/**/*.webm
production/**/*.jpg
production/**/*.jpeg
production/**/*.png
