# Claude Code private files
.claude/CLAUDE.local.md
.claude/settings.local.json
.claude/*.local.*

# Env & secrets
.env
.env.local
.env.*.local
*.key
*.pem

# Browser session storage / cookies / tokens (Shopee Session Fetcher v0)
# NEVER commit anything in .secrets/ — contains cookies, storageState, captcha
# screenshots, debug HTML snapshots with auth state, etc.
.secrets/
*.storage_state.json
*.session.json
*.cookies.json

# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.turbo/
*.tsbuildinfo

# Runtime data (local)
data/
data-*/

# Large backup archives
*.zip

# Admin tokens (auto-generated)
admin-token.txt

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Large binary media artifacts in production pipeline
production/**/*.mp4
production/**/*.mp3
production/**/*.m4a
production/**/*.wav
production/**/*.webm
production/**/*.mov
production/**/*.mkv
production/**/*.jpg
production/**/*.jpeg
production/**/*.png

# VFOS runtime commerce artifacts (root-level only — selected_products/ subdir
# stays tracked as canonical product card references)
production/_commerce/*.json

# VFOS-dedicated Cốc Cốc CDP profile (repo-fallback location only; normally
# lives under %LOCALAPPDATA%). Never commit a browser profile.
production/_commerce/coccoc_cdp_profile/

# VFOS production/archive runtime package output (production-packager.ts)
production/archive/**

# VFOS runtime reports / checkpoints / dashboards.
# Note: data/ is already ignored above; these `**` patterns add defense for
# alternate output locations and prevent accidental `git add -A` leak.
**/vfos_daily_status.json
**/vfos_daily_runbook.md
**/vfos_operator_checkpoint.json
**/vfos_operator_checkpoint.md
**/vfos_git_sync_status.json
**/facebook_publish_status.json
**/facebook_publish_report.md
**/operator_review_pack.json
**/operator_review_pack.md
