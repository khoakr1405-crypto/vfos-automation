# VFOS Kernel — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Voice / ElevenLabs ────────────────────────────────────────────────────────
# ElevenLabs TTS API key (required for voice:generate).
# Get yours at: https://elevenlabs.io → top-right avatar → Profile → API Keys
ELEVENLABS_API_KEY=

# VFOS brand voice — chốt 2026-05-20. ONE voice for all VFOS output.
# Default: ZqE9vIHPcrC35dZv0Svu (set this exactly unless you have explicit
# operator approval to A/B test). The old voice_01..voice_05 multi-preset
# system has been retired — do not re-introduce.
ELEVENLABS_VOICE_ID=ZqE9vIHPcrC35dZv0Svu

# ElevenLabs model — VFOS standardizes on eleven_v3 for expressive Vietnamese.
# Audio tags (e.g. [excited], [whispers]) only work with eleven_v3.
# WARNING: eleven_multilingual_v2 does NOT support Vietnamese — do not use.
ELEVENLABS_MODEL_ID=eleven_v3

# Path to ffprobe binary (for audio duration checking after TTS generation).
# If ffprobe is in PATH, leave blank. On Windows with WinGet ffmpeg, set to full path:
# FFPROBE_PATH=C:\Users\<you>\AppData\Local\Microsoft\WinGet\Packages\yt-dlp.FFmpeg_...\bin\ffprobe.exe
FFPROBE_PATH=

# ── AI ────────────────────────────────────────────────────────────────────────
# Real Anthropic API key. If unset, kernel falls back to mock driver.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required for script:generate / AI Script Writer).
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenAI model for Script Writer. Defaults to gpt-4o-mini.
# Recommended: gpt-4o-mini (cheap, strong JSON), gpt-4o (better Vietnamese prose).
OPENAI_MODEL=gpt-4o-mini

# Daily AI spend ceiling per tenant (USD). Default: 5.
BUDGET_DAILY_USD=5

# ── Server ────────────────────────────────────────────────────────────────────
KERNEL_PORT=3000
KERNEL_HOST=0.0.0.0
KERNEL_PUBLIC_ORIGIN=http://localhost:3000
COCKPIT_ORIGIN=http://localhost:3001

# ── Tenant ────────────────────────────────────────────────────────────────────
TENANT_DEFAULT_ID=00000000-0000-0000-0000-000000000001

# ── Storage & Data ────────────────────────────────────────────────────────────
# Directory for SQLite DB, blobs, credentials. Default: <workspace>/data.
# DATA_DIR=/path/to/data

# ── Queues (optional — in-memory if unset) ────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# AES-256 credential key for encrypting tenant API keys at rest.
# Auto-generated on first boot if unset; set explicitly for multi-instance.
# VFOS_CREDENTIAL_KEY=<32-byte hex>

# ── Social connectors (optional) ──────────────────────────────────────────────
TIKTOK_MODE=mock

# META_MODE — HARD safety gate cho @vfos/facebook publish surface.
#   - mock (DEFAULT): publishTextPost() KHÔNG gọi Graph API thật, trả về mock
#     result. `pnpm facebook:test-post` chạy là dry-run, an toàn để test.
#   - live: publishTextPost() gọi Graph API thật. CHỈ dùng khi operator
#     đã review thủ công + có flag --confirm-publish + .env có
#     FACEBOOK_PAGE_ID + FACEBOOK_PAGE_ACCESS_TOKEN hợp lệ.
# Mặc định phải là mock. KHÔNG đổi sang live trừ khi operator chủ động.
META_MODE=mock

# TIKTOK_CLIENT_KEY=...
# TIKTOK_CLIENT_SECRET=...

# Meta App credentials — BẮT BUỘC cho `pnpm facebook:get-page-token` (đổi Page
# token dài hạn). Lấy tại: developers.facebook.com → chọn App RIÊNG của bạn →
# Settings → Basic (App Secret bấm "Show"). App "Graph API Explorer" mặc định
# của Meta KHÔNG dùng được vì bạn không có secret của nó.
META_APP_ID=
META_APP_SECRET=

# ── Facebook Page (for Reels publishing via Shopee-First Lane) ────────────────
# Your Facebook Page ID. Find it in Page Settings → About → Page ID.
FACEBOOK_PAGE_ID=
# Page Access Token — dùng bản DÀI HẠN, không dán token ngắn hạn 1-2h.
# Cách lấy (1 lần mỗi ~60 ngày hoặc khi token chết):
#   1. Graph Explorer (https://developers.facebook.com/tools/explorer/) → chọn
#      App RIÊNG → User Token → quyền: pages_show_list, pages_read_engagement,
#      pages_manage_posts, pages_read_user_content → Generate → copy.
#   2. Dán token đó vào key này (tạm thời, còn ngắn hạn).
#   3. Chạy: pnpm facebook:get-page-token
#      → script exchange sang dài hạn (Page token từ long-lived user token theo
#        Meta docs KHÔNG hết hạn), verify bằng debug_token rồi TỰ ghi đè key này.
# WARNING: Never commit real tokens. This file is .env.example (template only).
# Live publish REQUIRES: META_MODE=live + --confirm-publish flag + non-empty
# FACEBOOK_PAGE_ID + FACEBOOK_PAGE_ACCESS_TOKEN. See packages/facebook/README.md.
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Shopee Affiliate / Cốc Cốc CDP auto-launch ────────────────────────────────
# Required for Round 27B browser auto-launch (Commerce Product Agent Shopee CDP).
# Must point to a dedicated Cốc Cốc/Chrome user data directory that is already
# logged in to Shopee Affiliate.
#
# Windows example:
# VFOS_BROWSER_USER_DATA_DIR=C:\Users\Admin\AppData\Local\CocCoc\Browser\User Data\VFOS-Shopee
#
# Safety:
# - Do not point this to an empty/random profile (login wall → CAPTCHA loop).
# - Do not commit your real local path in .env.
# - .env is local-only and must stay gitignored.
# Missing this env → bootstrap refuses to launch with ERR_CDP_USER_DATA_DIR_REQUIRED.
VFOS_BROWSER_USER_DATA_DIR=

# Optional: browser executable path if VFOS cannot auto-detect Cốc Cốc.
# Leave blank to auto-detect (Cốc Cốc Program Files / LOCALAPPDATA, then Chrome).
#
# Windows example:
# VFOS_BROWSER_PATH=C:\Program Files\CocCoc\Browser\Application\browser.exe
VFOS_BROWSER_PATH=

# Shopee Affiliate owner id used to validate generated affiliate links.
# Links whose owner id mismatches are rejected (ERR_AFFILIATE_OWNER_MISMATCH).
SHOPEE_AFFILIATE_OWNER_ID=an_17376660568

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: fatal error warn info debug trace. Default: info.
LOG_LEVEL=info
NODE_ENV=development
